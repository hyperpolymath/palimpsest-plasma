<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= page.title %> · <%= site_title %></title>
    <meta name="description" content="<%= page.description || site_title %>" />
    <link rel="stylesheet" href="/assets/style.css" />
  </head>
  <body>
    <header>
      <div class="eyebrow">Palimpsest Plasma</div>
      <h1><%= page.title %></h1>
      <p class="lead"><%= page.description || "Palimpsest compliance guidance" %></p>
      <nav>
        <%= for item <- nav do %>
          <a href="/<%= item.slug %>.html"><%= item.title %></a>
        <% end %>
      </nav>
    </header>
    <main>
      <%= content %>
    </main>
    <footer>
      <p>&copy; 2026 Palimpsest Plasma · code MPL-2.0 · docs CC-BY-SA-4.0</p>
    </footer>
  </body>
</html>
